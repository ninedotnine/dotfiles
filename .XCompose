#  necessary?
include "%L"

# french
# change default `mk u '` from uacute to ugrave.
<Multi_key> <u> <apostrophe> :  "ù" ugrave
<Multi_key> <apostrophe> <u> :  "ù" ugrave
<Multi_key> <U> <apostrophe> :  "Ù" Ugrave
<Multi_key> <apostrophe> <U> :  "Ù" Ugrave

# non-breaking spaces
<Multi_key> <ampersand> <space> :   " " nobreakspace    # espace insecable
<Multi_key> <bar>       <space> :   " " U202F           # espace fine insecable


# unusual or IPA letters
<Multi_key> <e> <j>     :   "ʒ" ezh
<Multi_key> <j> <e>     :   "ʒ" ezh
<Multi_key> <e> <z> <h> :   "ʒ" ezh
<Multi_key> <E> <J>     :   "Ʒ" EZH
